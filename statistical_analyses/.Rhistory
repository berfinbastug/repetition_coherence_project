mutate(false_alarm = mean_yes)
# PERCENTAGE == 0
fa_data <- data %>% filter(percentage == "0")
# If mean_yes is already the proportion of "yes" responses:
fa_data <- fa_data %>%
mutate(false_alarm = mean_yes)
